# Resend (required in production)
RESEND_API_KEY=re_your_api_key

# Verified sender in Resend for ibraheemuthman.com
CONTACT_FROM_EMAIL=Ibraheem Uthman <hello@ibraheemuthman.com>

# Comma-separated inbox list for new contact submissions
CONTACT_NOTIFY_EMAILS=hello@ibraheemuthman.com,uthibraheem@gmail.com

# Public site URL used for origin checks and email links
PUBLIC_SITE_URL=https://ibraheemuthman.com

# ---
# Cloudflare Workers (Git-connected build)
#
# Cloudflare runs `pnpm install --frozen-lockfile` before your build command.
#
# Build command:  pnpm build
# Deploy command:  pnpm run deploy
#
# Build env vars (encrypted in Cloudflare dashboard):
#   CLOUDFLARE_API_TOKEN  — token with Account → Workers Scripts → Edit
#   CLOUDFLARE_ACCOUNT_ID — 9261065c0eada470d066a7ac440e365f
#
# Runtime env vars (Workers → Settings → Variables):
#   RESEND_API_KEY, CONTACT_FROM_EMAIL, CONTACT_NOTIFY_EMAILS, PUBLIC_SITE_URL
#
# Local preview: copy .dev.vars.example to .dev.vars, then pnpm build && pnpm preview
