# Resend (required in production)
RESEND_API_KEY=re_your_api_key

# Verified sender in Resend for ibraheemuthman.com
CONTACT_FROM_EMAIL=Ibraheem Uthman <hello@ibraheemuthman.com>

# Comma-separated inbox list for new contact submissions
CONTACT_NOTIFY_EMAILS=hello@ibraheemuthman.com,uthibraheem@gmail.com

# Public site URL used for origin checks and email links
PUBLIC_SITE_URL=https://ibraheemuthman.com

# ---
# Cloudflare Pages: set the same variables in
# Workers & Pages → your project → Settings → Environment variables
# (mark RESEND_API_KEY as encrypted).
#
# Local Cloudflare preview: copy .dev.vars.example to .dev.vars
# then run `pnpm build && pnpm preview`.
