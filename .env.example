# Resend (required in production)
RESEND_API_KEY=re_your_api_key

# Verified sender in Resend for ibraheemuthman.com
CONTACT_FROM_EMAIL=Ibraheem Uthman <hello@ibraheemuthman.com>

# Comma-separated inbox list for new contact submissions
CONTACT_NOTIFY_EMAILS=hello@ibraheemuthman.com,uthibraheem@gmail.com

# Public site URL used for origin checks and email links
PUBLIC_SITE_URL=https://ibraheemuthman.com

# ---
# Cloudflare Pages (Git-connected — recommended)
#
# Cloudflare already runs `pnpm install --frozen-lockfile` before your build.
# Do NOT use `wrangler pages deploy` in CI unless you fix API token permissions.
# Pages publishes the build output directory automatically.
#
# Build command:     pnpm build
# Build output dir:  .svelte-kit/cloudflare
# Deploy command:    pnpm run deploy
#
# Manual CLI deploy (local machine only): pnpm build && pnpm run pages:deploy
#
# Environment variables (Workers & Pages → Settings → Variables):
#   RESEND_API_KEY (encrypted), CONTACT_FROM_EMAIL, CONTACT_NOTIFY_EMAILS, PUBLIC_SITE_URL
#
# Local preview: copy .dev.vars.example to .dev.vars, then pnpm build && pnpm preview
