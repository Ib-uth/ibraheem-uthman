# Resend (required in production)
RESEND_API_KEY=re_your_api_key

# Verified sender in Resend for ibraheemuthman.com
CONTACT_FROM_EMAIL=Ibraheem Uthman <hello@ibraheemuthman.com>

# Comma-separated inbox list for new contact submissions
CONTACT_NOTIFY_EMAILS=hello@ibraheemuthman.com,uthibraheem@gmail.com

# Public site URL used for origin checks, SEO, and email links
PUBLIC_SITE_URL=https://www.ibraheemuthman.com

# ---
# Vercel (import GitHub repo: Ib-uth/ibraheem-uthman)
#
# Framework preset: SvelteKit (auto-detected)
# Build command:     pnpm build
# Install command:   pnpm install
# Output directory:  (leave default — adapter handles this)
#
# Environment variables (Project → Settings → Environment Variables):
#   RESEND_API_KEY, CONTACT_FROM_EMAIL, CONTACT_NOTIFY_EMAILS, PUBLIC_SITE_URL
#
# Local dev: copy this file to .env and fill in values, then pnpm dev
